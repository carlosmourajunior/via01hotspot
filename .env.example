# ═══ Arquivo .env unificado (raiz) — copie para .env e preencha ═══
# Usado pelos serviços "portal" e "admin" do docker-compose.

# ─── UniFi Controller ──────────────────────────────────────────────
UNIFI_URL=https://SEU_IP_DO_CONTROLLER:11443
UNIFI_API_KEY=sua_api_key_aqui   # gerada em Settings → Control Plane → Integrations
UNIFI_SITE=default               # internalReference do site no UniFi (geralmente "default")

# ─── Evolution API (WhatsApp / OTP) ────────────────────────────────
# Rodando via docker-compose, EVOLUTION_URL é sobrescrita pelo compose
# (usa o nome do serviço "evolution-api" e a porta interna do container).
EVOLUTION_URL=http://localhost:8081
EVOLUTION_API_KEY=sua_api_key_aqui
EVOLUTION_INSTANCE=hotspot       # nome da instância criada na Evolution API

# ─── Portal captivo ────────────────────────────────────────────────
OTP_TTL_SECONDS=300              # OTP expira em 5 minutos
OTP_LENGTH=6
SUCCESS_REDIRECT_URL=https://www.via01.com.br

# ─── Banco de dados (admin + guests do portal) ─────────────────────
DATABASE_URL=postgresql://controle:controle@db:5432/controle

# ─── Auth JWT (área administrativa) ────────────────────────────────
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# ─── Integração IXC ────────────────────────────────────────────────
IXC_HOST=seu-ixc.provedor.com.br
IXC_TOKEN=id:token_aqui
IXC_CACHE_TTL_SECONDS=600

# ─── OneDrive (planilhas de leads/vendas) ──────────────────────────
ONEDRIVE_SHARE_URL=https://1drv.ms/x/...
CACHE_TTL_SECONDS=300
