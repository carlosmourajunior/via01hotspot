# ─── UniFi Controller ──────────────────────────────────────────────
UNIFI_URL=https://SEU_IP_DO_CONTROLLER:11443
UNIFI_API_KEY=sua_api_key_aqui   # gerada em Settings → Control Plane → Integrations
UNIFI_SITE=default          # internalReference do site no UniFi (geralmente "default")

# ─── Evolution API ─────────────────────────────────────────────────
EVOLUTION_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_api_key_aqui
EVOLUTION_INSTANCE=hotspot  # nome da instância criada na Evolution API

# ─── Portal ────────────────────────────────────────────────────────
PORT=3000
OTP_TTL_SECONDS=300         # OTP expira em 5 minutos
OTP_LENGTH=6
